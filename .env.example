# Copy to .env for local dev, or use Doppler: docs/doppler-secrets.md
# Messenger / Meta
PAGE_ACCESS_TOKEN=EAABxxxxxxxxxxxxxxxx
VERIFY_TOKEN=wispace_verify_token
# App Secret (Meta App Dashboard → Settings → Basic) — verify POST /webhook
MESSENGER_APP_SECRET=replace-with-meta-app-secret
# true | false — default: true when MESSENGER_APP_SECRET is set; false when unset
MESSENGER_WEBHOOK_SIGNATURE_VERIFY=true
PORT=3000
GRAPH_API_VERSION=v21.0
MESSENGER_PAGE_ID=1192471430606671
MESSENGER_PAGE_USERNAME=

# OpenAI (báo cáo, nhắc lịch, chat agent)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.4

# WISPACE API — auth header x-psid (PSID Messenger)
# Retry cho tất cả Wispace API GET (5xx + network error); POST/DELETE không retry
WISPACE_API_MAX_RETRIES=3
WISPACE_API_RETRY_BASE_DELAY_MS=500

WISPACE_API_TASK_SCORE_URL=https://backend.aihubproduction.com/api/TaskScoreAverage
WISPACE_API_USER_GOALS_URL=https://backend.aihubproduction.com/api/User/goals
WISPACE_API_USER_CALENDAR_URL=https://backend.aihubproduction.com/api/UserCalendar
WISPACE_API_STUDY_SCHEDULE_URL=https://backend.aihubproduction.com/api/StudySchedule

# Báo cáo học tập tự động (cron 08:00)
WISPACE_REPORT_DAYS_BEFORE_EXAM_MIN=2
WISPACE_REPORT_DAYS_BEFORE_EXAM_MAX=3

# Report send outbox retry (R5) — Wispace 5xx cron báo cáo
REPORT_SEND_MAX_RETRIES=3
REPORT_SEND_RETRY_BACKOFF_MINUTES=15
REPORT_SEND_RETRY_POLL_MINUTES=15
# Parallel Wispace+OpenAI calls per batch trong cron 08:00 (default 5)
REPORT_SEND_CONCURRENCY=5

# Nhắc lịch học (study_reminder_jobs)
# Adaptive dispatch poll: thay vì poll cố định 1 phút, tự điều chỉnh theo job tiếp theo
STUDY_REMINDER_POLL_MIN_MS=30000    # poll nhanh nhất mỗi 30s
STUDY_REMINDER_POLL_MAX_MS=210000   # poll chậm nhất mỗi 3.5 phút (khi không có job)
STUDY_REMINDER_POLL_LEAD_MS=60000   # wake up sớm hơn 60s so với job tiếp theo
STUDY_REMINDER_MINUTES_BEFORE=30
STUDY_REMINDER_MIN_LEAD_MINUTES=1
STUDY_REMINDER_SYNC_HORIZON_HOURS=336
STUDY_REMINDER_MAX_RETRIES=3
STUDY_REMINDER_RETRY_BACKOFF_MINUTES=2
STUDY_REMINDER_JOB_RETENTION_DAYS=7
STUDY_REMINDER_EVENING_ROLLOVER_HOUR=23
STUDY_REMINDER_TIMEZONE=Asia/Ho_Chi_Minh

# Chat tự do Messenger (queue, typing, chia bubble)
CHAT_DEBOUNCE_MS=2000
CHAT_MAX_BUBBLES=4
CHAT_BUBBLE_MAX_CHARS=640

# Rate limit chat tự do (FREE_FORM) — Phase 0+; enforcement từ Phase 3
# Production/VPS: set true (H1). Local dev có thể để false.
CHAT_RATE_LIMIT_ENABLED=false
CHAT_FREE_FORM_DAILY_LIMIT=15
CHAT_BURST_PER_MINUTE=3
CHAT_USAGE_TIMEZONE=Asia/Ho_Chi_Minh
# PSID QA không bị limit (comma-separated, optional)
CHAT_RATE_LIMIT_WHITELIST_PSIDS=
# VPS: bật cảnh báo startup nếu quota tắt khi NODE_ENV khác production
ENFORCE_PROD_CHAT_QUOTA=false
# Q1 smoke script (npm run q1:smoke) — URL app đang chạy
Q1_SMOKE_BASE_URL=http://127.0.0.1:3000
# Hiện "còn X lượt" sau reply khi remaining <= ngưỡng (Phase 6 UX)
CHAT_QUOTA_REMAINING_HINT_THRESHOLD=3
# H2: reserved kẹt quá TTL (ms) → refund + cho Meta retry cùng message.mid (default 600000 = 10 phút)
CHAT_IDEMPOTENCY_STUCK_RESERVED_MS=600000
# H5: cap độ dài text sau debounce merge trước LLM (default 4000)
CHAT_MERGED_TEXT_MAX_CHARS=4000
# H5: burst 60s có đếm refunded không (false = không đếm, khuyến nghị)
CHAT_BURST_COUNT_REFUNDED=false
# R3: burst counter backend — postgres (default) | memory | redis
CHAT_BURST_STORE=postgres
# H6: xóa idempotency completed/refunded cũ hơn N ngày (script chat-quota:cleanup)
CHAT_IDEMPOTENCY_RETENTION_DAYS=90
# H7 legacy: CHAT_QUEUE_SHARED=true → map CHAT_QUEUE_STORE/CHAT_HISTORY_STORE=redis khi không set explicit
CHAT_QUEUE_SHARED=false
CHAT_QUEUE_PROCESSING_STUCK_MS=300000
CHAT_WEBHOOK_DEDUPE_RETENTION_MS=86400000
# R1: LLM context — memory (default) | redis (postgres table removed)
# redis → cần REDIS_ENABLED=true; key chat:history:{psid}
CHAT_HISTORY_STORE=memory
CHAT_HISTORY_TTL_MS=1800000
CHAT_HISTORY_MAX_MESSAGES=12
# R2: webhook dedupe — memory | redis (postgres DB table removed)
# redis → dedupe:mid:* + dedupe:postback:*
CHAT_DEDUPE_STORE=redis
# R4: debounce queue backend — memory (default) | redis (postgres table removed)
# redis → chat:queue:buffer:{psid}; CHAT_QUEUE_SHARED=true → redis khi không set explicit
CHAT_QUEUE_STORE=memory

# Redis (VPS — dùng chung local + production; maxmemory 256mb)
# R0: kết nối + GET /health/redis | R1–R4: history, dedupe, burst, queue stores
REDIS_ENABLED=false
REDIS_HOST=69.62.74.196
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-redis-password
# R5: cache display name từ bảng users — key cache:user:display:{userId}
USER_DISPLAY_NAME_CACHE_ENABLED=true
USER_DISPLAY_NAME_CACHE_TTL_SECONDS=3600

# Ops health alerts (I1 + S1) — cron 09:00 ICT + scripts ops:health
OPS_HEALTH_ALERT_ENABLED=true
OPS_ALERT_FAILED_JOBS_HOURS=24
OPS_ALERT_STUCK_PROCESSING_MINUTES=10
OPS_ALERT_DENY_LOOKBACK_HOURS=24
OPS_ALERT_MIN_FAILED_JOBS=1
OPS_ALERT_MIN_STUCK_RESERVED=1
OPS_ALERT_MIN_STUCK_PROCESSING=1

# Report cron scale (R4) — multi-pod 08:00 báo cáo
CRON_LEADER_ENABLED=false
CRON_LEADER_INSTANCE_ID=
INSTANCE_ID=

# Webhook dead-letter auto-retry (cron mỗi 5 phút)
WEBHOOK_DEAD_LETTER_MAX_RETRIES=5
WEBHOOK_DEAD_LETTER_MIN_RETRY_AGE_MS=60000
WEBHOOK_DEAD_LETTER_RETRY_LIMIT=20

# messenger_message_logs audit retention — cron 03:00 ICT ngày 1 hàng tháng
MESSENGER_MESSAGE_LOG_CLEANUP_ENABLED=true
MESSENGER_MESSAGE_LOG_RETENTION_DAYS=90

# Ops HTTP — header X-Internal-Api-Key hoặc Authorization: Bearer
INTERNAL_API_KEY=replace-with-a-long-random-secret

# PostgreSQL — DB dedicated POC Messenger (prod: ai_chat_bot_db)
# Legacy hub Wispace: writing_ai_hub_db (đã drop bảng POC; không dùng cho app)
DB_HOST=69.62.74.196
DB_PORT=5434
DB_NAME=ai_chat_bot_db
DB_USER=ielts_admin
DB_PASSWORD=your_password_here
DB_SSL=false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false
