# Biến dùng CHUNG cho mọi bot (messenger-bot, discord-bot, zalo-bot sau này).
# Copy thành `.env.shared` ở root (không commit) — mỗi app tự đọc file này
# làm fallback qua ConfigModule.forRoot({ envFilePath: ['.env', '../../.env.shared'] }).
# App's own `.env` luôn override nếu trùng key.
#
# Biến ĐẶC TRƯNG platform (token, client id/secret, verify-token URL riêng...)
# vẫn nằm trong .env.example của từng app — KHÔNG đưa vào đây.
#
# Production (Doppler): xem docs/doppler-secrets.md — thay vì copy tay các
# giá trị này vào từng Doppler project, dùng Doppler secret reference từ
# project `wispace-shared` chung.

# WISPACE API — auth server-to-server
WISPACE_INTERNAL_KEY=replace-with-wispace-internal-key
# Account-link token verify — same URL for all 3 bots, payload { token, value, platform }
WISPACE_API_VERIFY_TOKEN_URL=https://backend.aihubproduction.com/api/User/verify-token-url
WISPACE_API_MAX_RETRIES=3
WISPACE_API_RETRY_BASE_DELAY_MS=500
WISPACE_API_USER_GOALS_URL=https://backend.aihubproduction.com/api/User/goals
WISPACE_API_TASK_SCORE_URL=https://backend.aihubproduction.com/api/TaskScoreAverage
WISPACE_API_USER_CALENDAR_URL=https://backend.aihubproduction.com/api/UserCalendar

# Nhắc lịch học — timezone/horizon/min-lead dùng chung mọi bot đọc/ghi lịch WISPACE
STUDY_REMINDER_TIMEZONE=Asia/Ho_Chi_Minh
STUDY_REMINDER_SYNC_HORIZON_HOURS=336
STUDY_REMINDER_MIN_LEAD_MINUTES=1

# OpenAI (chat agent, báo cáo)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.4
OPENAI_MAX_TOOL_ROUNDS=6
OPENAI_MAX_CONTEXT_CHARS=24000
OPENAI_MAX_OUTPUT_TOKENS=1024

# LLM usage/cost tracking (@wispace/chat-metering)
LLM_USAGE_ENABLED=true
LLM_USAGE_TIMEZONE=Asia/Ho_Chi_Minh
LLM_COST_USD_PER_1M_INPUT_TOKENS_GPT_5_4=2.50
LLM_COST_USD_PER_1M_OUTPUT_TOKENS_GPT_5_4=15.00
# Optional — giá cached input (OpenAI prompt caching). Nếu bỏ trống, mặc định = 50% giá input.
# LLM_COST_USD_PER_1M_CACHED_INPUT_TOKENS_GPT_5_4=1.25
CHAT_USAGE_TIMEZONE=Asia/Ho_Chi_Minh

# PostgreSQL — DB chung mọi bot (Phase 2: khóa (platform, external_user_id))
DB_HOST=69.62.74.196
DB_PORT=5434
DB_NAME=ai_chat_bot_db
DB_USER=ielts_admin
DB_PASSWORD=your_password_here
DB_SSL=false
DB_LOGGING=false
