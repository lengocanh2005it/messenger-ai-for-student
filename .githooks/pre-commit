#!/bin/sh
# Fast check on staged files only — format + lint. Full verify runs at pre-push.
set -e

STAGED_ALL_TS=$(git diff --cached --name-only --diff-filter=ACMR -- '*.ts' '*.tsx' || true)

if [ -z "$STAGED_ALL_TS" ]; then
  exit 0
fi

echo "[pre-commit] prettier --check on staged .ts files..."
echo "$STAGED_ALL_TS" | xargs npx prettier --check

echo "[pre-commit] eslint on staged .ts files..."
echo "$STAGED_ALL_TS" | xargs npx eslint
