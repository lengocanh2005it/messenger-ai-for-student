# Copy this to .env for local dev — platform-specific only. Biến dùng chung
# mọi bot (WISPACE_INTERNAL_KEY, OPENAI_*, DB_*, STUDY_REMINDER_*...) nằm ở
# root .env.shared.example — xem docs/doppler-secrets.md.
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
PORT=3001

# Discord OAuth2 account-linking (Discord userId <-> WISPACE userId) — see
# apps/discord-bot/docs/discord-account-linking.md for the WISPACE-side contract
DISCORD_CLIENT_ID=replace-with-discord-application-client-id
DISCORD_CLIENT_SECRET=replace-with-discord-application-client-secret
DISCORD_OAUTH_REDIRECT_URI=https://discord-bot.example.com/discord/oauth/callback

# URL trang FE nhận kết quả OAuth (backend redirect về đây sau callback)
# Local dev mock FE: http://localhost:4321/callback.html
DISCORD_OAUTH_FRONTEND_CALLBACK_URL=

# Dev-only bypass: bỏ qua WISPACE verify khi token khớp DISCORD_DEV_LINK_TOKEN
# Chỉ dùng cho local test — KHÔNG đặt trong production
DISCORD_DEV_LINK_TOKEN=
DISCORD_DEV_LINK_USER_ID=
# Chat rate limit (quota FREE_FORM) — tuning riêng Discord, khác Messenger
CHAT_RATE_LIMIT_ENABLED=false
CHAT_FREE_FORM_DAILY_LIMIT=30
CHAT_BURST_PER_MINUTE=5

# Guild membership check — set to your Discord server ID to enforce join-before-link
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=https://discord.gg/R3CS2WEu
