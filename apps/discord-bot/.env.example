DISCORD_BOT_TOKEN=replace-with-discord-bot-token
PORT=3001

# Discord OAuth2 account-linking (Discord userId <-> WISPACE userId) — see
# apps/discord-bot/docs/discord-account-linking.md for the WISPACE-side contract
DISCORD_CLIENT_ID=replace-with-discord-application-client-id
DISCORD_CLIENT_SECRET=replace-with-discord-application-client-secret
DISCORD_OAUTH_REDIRECT_URI=https://discord-bot.example.com/discord/oauth/callback

# WISPACE's existing account-link token verify API (same shape as Messenger's
# WISPACE_API_VERIFY_MESSENGER_TOKEN_URL, generalized with a platform field)
WISPACE_API_VERIFY_DISCORD_TOKEN_URL=https://backend.aihubproduction.com/api/User/verify-discord-token
WISPACE_INTERNAL_KEY=replace-with-wispace-internal-key

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5.4
OPENAI_MAX_TOOL_ROUNDS=6
OPENAI_MAX_CONTEXT_CHARS=24000

# Shared Postgres DB (same instance/schema as apps/messenger-bot — Phase 2)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_chat_bot_db
DB_SSL=false
DB_LOGGING=false

# Chat rate limit (quota FREE_FORM) — disabled by default
CHAT_RATE_LIMIT_ENABLED=false
CHAT_FREE_FORM_DAILY_LIMIT=30
CHAT_BURST_PER_MINUTE=5
CHAT_USAGE_TIMEZONE=Asia/Ho_Chi_Minh

# LLM usage/safety event tracking (@wispace/chat-metering, platform=discord)
LLM_USAGE_ENABLED=true
LLM_USAGE_TIMEZONE=Asia/Ho_Chi_Minh
LLM_COST_USD_PER_1M_INPUT_TOKENS_GPT_5_4=2.50
LLM_COST_USD_PER_1M_OUTPUT_TOKENS_GPT_5_4=15.00

# Wispace API tool handlers (@wispace/wispace-client, x-discordid header) — goals/report/calendar tools
WISPACE_API_USER_GOALS_URL=https://backend.aihubproduction.com/api/User/goals
WISPACE_API_TASK_SCORE_URL=https://backend.aihubproduction.com/api/TaskScoreAverage
WISPACE_API_USER_CALENDAR_URL=https://backend.aihubproduction.com/api/UserCalendar
WISPACE_API_MAX_RETRIES=3
WISPACE_API_RETRY_BASE_DELAY_MS=500
STUDY_REMINDER_TIMEZONE=Asia/Ho_Chi_Minh
STUDY_REMINDER_SYNC_HORIZON_HOURS=336
