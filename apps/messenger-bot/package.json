{
  "name": "@wispace/messenger-bot",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --cache --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:doppler": "doppler run -- npm run start:dev",
    "env:sync-prod": "gh workflow run sync-env.yml",
    "env:upload-doppler": "node scripts/upload-env-to-doppler.mjs .env",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:inspect": "node --env-file=.env scripts/inspect-db.mjs",
    "db:explore-study-schedule": "node --env-file=.env scripts/explore-study-schedule-db.mjs",
    "study-reminder:sync": "npm run build && npm run migration:run && node --env-file=.env scripts/sync-study-reminder-jobs.mjs",
    "study-reminder:sync-only": "npm run build && node --env-file=.env scripts/sync-study-reminder-jobs.mjs --sync-only",
    "study-reminder:jobs": "node --env-file=.env scripts/show-study-reminder-jobs.mjs",
    "ops:health": "node --env-file=.env scripts/ops-daily-health.mjs",
    "q1:smoke": "node --env-file=.env scripts/q1-smoke.mjs",
    "messenger:relink": "node --env-file=.env scripts/relink-messenger-mapping.mjs",
    "chat-quota:status": "node --env-file=.env scripts/chat-quota-status.mjs",
    "chat-quota:recover-stuck": "node --env-file=.env scripts/chat-quota-recover-stuck.mjs",
    "chat-quota:cleanup": "node --env-file=.env scripts/chat-quota-cleanup-idempotency.mjs",
    "chat-quota:rebuild": "node --env-file=.env scripts/chat-quota-rebuild.mjs",
    "llm-usage:status": "node --env-file=.env scripts/llm-usage-status.mjs",
    "webhook:dead-letter": "node --env-file=.env scripts/webhook-dead-letter.mjs",
    "migration:run": "npm run build && node --env-file=.env ./node_modules/typeorm/cli.js migration:run -d dist/infrastructure/database/data-source.js",
    "migration:revert": "npm run build && node --env-file=.env ./node_modules/typeorm/cli.js migration:revert -d dist/infrastructure/database/data-source.js",
    "migration:show": "npm run build && node --env-file=.env ./node_modules/typeorm/cli.js migration:show -d dist/infrastructure/database/data-source.js",
    "migration:generate": "npm run build && node --env-file=.env ./node_modules/typeorm/cli.js migration:generate -d dist/infrastructure/database/data-source.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-pg": "^0.71.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@wispace/chat-history": "*",
    "@wispace/chat-metering": "*",
    "@wispace/chat-queue-core": "*",
    "@wispace/llm-agent": "*",
    "@wispace/student-report": "*",
    "@wispace/study-reminder-core": "*",
    "@wispace/wispace-client": "*",
    "bullmq": "^5.79.0",
    "ioredis": "^5.11.1",
    "openai": "^6.42.0",
    "p-limit": "^3.1.0",
    "pg": "^8.21.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
